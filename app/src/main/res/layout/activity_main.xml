<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_background"
    android:padding="@dimen/margin_large">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingBottom="@dimen/margin_large">

            <!-- Logo Kelas -->
            <ImageView
                android:layout_width="@dimen/logo_size"
                android:layout_height="@dimen/logo_size"
                android:layout_marginTop="@dimen/margin_header"
                android:background="@drawable/bg_circle_logo"
                android:clipToOutline="true"
                android:contentDescription="Logo Kelas"
                android:elevation="6dp"
                android:scaleType="centerCrop"
                android:outlineProvider="background"
                app:srcCompat="@drawable/logo_kelas" />

            <!-- Informasi Tugas -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/margin_xlarge"
                android:layout_marginTop="@dimen/margin_xxlarge"
                app:cardBackgroundColor="@color/glass_card_bg"
                app:cardCornerRadius="@dimen/corner_large"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_large">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/info_title"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_large"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_small"
                        android:gravity="center"
                        android:text="@string/info_subtitle"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_xsmall" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Tombol Developer 1 -->
            <FrameLayout
                android:id="@+id/btnDev1"
                style="@style/GradientButton"
                android:layout_marginHorizontal="@dimen/margin_xlarge"
                android:layout_marginTop="@dimen/margin_xxlarge"
                android:background="@drawable/bg_primary_gradient"
                android:elevation="10dp"
                android:outlineProvider="background">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    style="@style/ButtonLabel"
                    android:text="@string/btn_dev1" />

            </FrameLayout>

            <!-- Tombol Developer 2 -->
            <FrameLayout
                android:id="@+id/btnDev2"
                style="@style/GradientButton"
                android:layout_marginHorizontal="@dimen/margin_xlarge"
                android:layout_marginTop="@dimen/margin_default"
                android:background="@drawable/bg_primary_gradient"
                android:elevation="10dp"
                android:outlineProvider="background">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    style="@style/ButtonLabel"
                    android:text="@string/btn_dev2" />

            </FrameLayout>

            <!-- Tombol Developer 3 -->
            <FrameLayout
                android:id="@+id/btnDev3"
                style="@style/GradientButton"
                android:layout_marginHorizontal="@dimen/margin_xlarge"
                android:layout_marginTop="@dimen/margin_default"
                android:background="@drawable/bg_primary_gradient"
                android:elevation="10dp"
                android:outlineProvider="background">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    style="@style/ButtonLabel"
                    android:text="@string/btn_dev3" />

            </FrameLayout>

            <!-- Tombol Instagram -->
            <FrameLayout
                android:id="@+id/btnInstagram"
                style="@style/GradientButton"
                android:layout_marginHorizontal="@dimen/margin_xlarge"
                android:layout_marginTop="@dimen/margin_xxlarge"
                android:background="@drawable/bg_instagram_gradient"
                android:elevation="10dp"
                android:outlineProvider="background">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    style="@style/ButtonLabel"
                    android:text="@string/btn_instagram" />

            </FrameLayout>

            <!-- Tombol Keluar -->
            <FrameLayout
                android:id="@+id/btnExit"
                android:layout_width="@dimen/btn_exit_width"
                android:layout_height="@dimen/btn_height_medium"
                android:layout_marginTop="@dimen/margin_large"
                android:background="@drawable/bg_exit_gradient"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:elevation="6dp"
                android:outlineProvider="background">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    style="@style/ButtonLabel"
                    android:text="@string/btn_exit" />

            </FrameLayout>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
