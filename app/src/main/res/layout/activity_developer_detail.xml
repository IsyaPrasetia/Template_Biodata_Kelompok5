<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/activity_developer_detail"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_background">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="@dimen/margin_large"
            android:paddingBottom="@dimen/margin_xxlarge">

            <!-- A. Header Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/profileImage"
                    android:layout_width="@dimen/header_profile_size"
                    android:layout_height="@dimen/header_profile_size"
                    android:background="@drawable/bg_circle_logo"
                    android:clipToOutline="true"
                    android:contentDescription="Foto Profil"
                    android:elevation="4dp"
                    android:outlineProvider="background"
                    android:padding="2dp"
                    android:scaleType="centerCrop" />

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/name_card_height"
                    android:layout_marginStart="@dimen/margin_medium"
                    android:layout_weight="1"
                    android:background="@drawable/bg_name_card"
                    android:elevation="2dp"
                    android:gravity="center"
                    android:outlineProvider="background"
                    android:textColor="@color/white_card_text"
                    android:textSize="@dimen/text_medium"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- B. Control Buttons Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_large"
                android:gravity="center"
                android:orientation="horizontal">

                <FrameLayout
                    android:id="@+id/btnBack"
                    android:layout_width="@dimen/control_btn_width"
                    android:layout_height="@dimen/control_btn_height"
                    android:background="@drawable/bg_white_rounded"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="6dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:outlineProvider="background">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                    android:text="@string/btn_kembali"
                        android:textColor="@color/white_card_text"
                        android:textSize="@dimen/text_small"
                        android:textStyle="bold" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/btnGitHub"
                    android:layout_width="@dimen/control_btn_width"
                    android:layout_height="@dimen/control_btn_height"
                    android:layout_marginStart="@dimen/margin_default"
                    android:background="@drawable/bg_github_gradient"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="6dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:outlineProvider="background">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_github"
                            android:contentDescription="GitHub" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/margin_small"
                            android:text="@string/btn_github"
                            android:textColor="@color/text_on_primary"
                            android:textSize="@dimen/text_small"
                            android:textStyle="bold" />
                    </LinearLayout>
                </FrameLayout>

            </LinearLayout>

            <!-- C. Biodata Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_large"
                app:cardBackgroundColor="@color/glass_card_bg"
                app:cardCornerRadius="@dimen/corner_large"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_default">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/SectionTitle"
                        android:text="@string/section_biodata" />

                    <TextView
                        android:id="@+id/tvAlamat"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_medium"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_xsmall"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDetailContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_small"
                        style="@style/SectionContent" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- D. Quick Links Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_large"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- Clock Widget -->
                <FrameLayout
                    android:id="@+id/btnClock"
                    android:layout_width="@dimen/clock_widget_width"
                    android:layout_height="@dimen/clock_widget_height"
                    android:background="@drawable/bg_clock_widget"
                    android:clickable="true"
                    android:elevation="6dp"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:outlineProvider="background">

                    <TextView
                        android:id="@+id/tvClock"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_medium"
                        android:textStyle="bold" />
                </FrameLayout>

                <!-- IG Circle -->
                <FrameLayout
                    android:id="@+id/btnIG"
                    android:layout_width="@dimen/quick_link_icon_size"
                    android:layout_height="@dimen/quick_link_icon_size"
                    android:layout_marginStart="@dimen/margin_default"
                    android:background="@drawable/bg_ig_circle"
                    android:clickable="true"
                    android:elevation="6dp"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:outlineProvider="background">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_instagram"
                        android:contentDescription="Instagram" />
                </FrameLayout>

                <!-- TikTok Circle with Neon -->
                <FrameLayout
                    android:id="@+id/btnTikTok"
                    android:layout_width="@dimen/tiktok_glow_size"
                    android:layout_height="@dimen/tiktok_glow_size"
                    android:layout_marginStart="@dimen/margin_default"
                    android:background="@drawable/bg_tiktok_circle"
                    android:clickable="true"
                    android:elevation="6dp"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:outlineProvider="background">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_tiktok"
                        android:contentDescription="TikTok" />
                </FrameLayout>

            </LinearLayout>

            <!-- E. Dan Lain Lain Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_large"
                app:cardBackgroundColor="@color/glass_card_bg"
                app:cardCornerRadius="@dimen/corner_large"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_default">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/modal_header"
                        android:textColor="@color/modal_header"
                        android:textSize="@dimen/text_medium"
                        android:textStyle="bold" />

                    <!-- Pendidikan -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_default"
                        android:text="@string/section_pendidikan"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_small"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvEduList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_small"
                        style="@style/SectionContent" />

                    <!-- Aktivitas -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_default"
                        android:text="@string/section_aktivitas"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_small"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAktivitas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_small"
                        style="@style/SectionContent" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Tombol Kembali -->
            <FrameLayout
                android:id="@+id/btnBackBottom"
                android:layout_width="200dp"
                android:layout_height="@dimen/btn_height_medium"
                android:layout_marginTop="@dimen/margin_xxlarge"
                android:background="@drawable/bg_back_button"
                android:clickable="true"
                android:elevation="6dp"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:outlineProvider="background">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    style="@style/ButtonLabel"
                    android:text="@string/btn_back"
                    android:textSize="@dimen/text_small" />

            </FrameLayout>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
